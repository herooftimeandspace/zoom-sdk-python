                                "type": "string",
                                "description": "The caller's phone number in E.164 format."
                              },
                              "to": {
                                "type": "string",
                                "description": "The recipient's phone number in E.164 format."
                              },
                              "interaction_id": {
                                "type": "string",
                                "description": "The interaction ID."
