{
  "openapi": "3.0.0",
  "info": {
    "title": "PBX Sideloaded"
  },
  "servers": [
    {
      "url": "https://us01pbx.zoom.us"
    }
  ],
  "paths": {
    "/api/v2/pbx/account/{accountId}/device/{deviceId}": {
      "get": {
        "operationId": "getPbxDevice",
        "summary": "Get PBX device details",
        "x-sdk": {
          "namespace": ["pbx", "devices"],
          "alias": "get"
        },
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PBX device details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accountId": {"type": "string"},
                    "areaCode": {"type": "string"},
                    "deviceId": {"type": "string"},
                    "name": {"type": "string"},
                    "description": {"type": "string"},
                    "status": {"type": "integer"},
                    "manufacturerId": {"type": "string"},
                    "manufacturerName": {"type": "string"},
                    "modelId": {"type": "string"},
                    "siteId": {"type": "string"},
                    "privateIp": {"type": "string"},
                    "registrationPublicIp": {"type": "string"},
                    "serialNumber": {"type": "string"},
                    "userAgent": {"type": "string"},
                    "extensionIds": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "extensions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "extensionId": {"type": "string"},
                          "displayName": {"type": "string"},
                          "extensionNumber": {"type": "string"}
                        },
                        "additionalProperties": true
                      }
                    },
                    "phoneModel": {
                      "type": "object",
                      "properties": {
                        "modelId": {"type": "string"},
                        "manufacturerId": {"type": "string"},
                        "modelName": {"type": "string"},
                        "manufacturerName": {"type": "string"},
                        "displayName": {"type": "string"}
                      },
                      "additionalProperties": true
                    }
                  },
                  "required": ["accountId", "deviceId"],
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updatePbxDevice",
        "summary": "Update PBX device details",
        "x-sdk": {
          "namespace": ["pbx", "devices"],
          "alias": "update"
        },
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "description": {"type": "string"}
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PBX device details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accountId": {"type": "string"},
                    "areaCode": {"type": "string"},
                    "deviceId": {"type": "string"},
                    "name": {"type": "string"},
                    "description": {"type": "string"},
                    "status": {"type": "integer"},
                    "manufacturerId": {"type": "string"},
                    "manufacturerName": {"type": "string"},
                    "modelId": {"type": "string"},
                    "siteId": {"type": "string"},
                    "privateIp": {"type": "string"},
                    "registrationPublicIp": {"type": "string"},
                    "serialNumber": {"type": "string"},
                    "userAgent": {"type": "string"},
                    "extensionIds": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "extensions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "extensionId": {"type": "string"},
                          "displayName": {"type": "string"},
                          "extensionNumber": {"type": "string"}
                        },
                        "additionalProperties": true
                      }
                    },
                    "phoneModel": {
                      "type": "object",
                      "properties": {
                        "modelId": {"type": "string"},
                        "manufacturerId": {"type": "string"},
                        "modelName": {"type": "string"},
                        "manufacturerName": {"type": "string"},
                        "displayName": {"type": "string"}
                      },
                      "additionalProperties": true
                    }
                  },
                  "required": ["accountId", "deviceId"],
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/pbx/account/{accountId}/device/extension/s": {
      "get": {
        "operationId": "listPbxDeviceExtensions",
