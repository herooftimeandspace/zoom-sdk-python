    "/api/v2/pbx/account/{accountId}/service-endpoints": {
      "get": {
        "operationId": "listPbxServiceEndpoints",
        "summary": "List PBX service endpoints",
        "x-sdk": {
          "namespace": ["pbx", "devices"],
          "alias": "list_service_endpoints"
        },
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PBX service endpoints page.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pageNumber": {"type": "integer"},
                    "pageSize": {"type": "integer"},
                    "pageTotal": {"type": "integer"},
                    "recordsTotal": {"type": "integer"},
                    "total": {"type": "integer"},
                    "records": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  },
                  "required": ["records"],
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
