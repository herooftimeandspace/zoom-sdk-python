              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "extensionId": {"type": "string"},
                      "displayName": {"type": "string"},
                      "extensionNumber": {"type": "string"},
                      "level": {"type": "integer"},
                      "status": {"type": "integer"},
                      "phoneStatus": {"type": "integer"},
                      "siteId": {"type": "string"}
                    },
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
      }
    },
