  "webhooks": {
    "commerce.account_status_changed": {
      "post": {
        "tags": [
          "commerce"
        ],
        "operationId": "commerce.account_status_changed",
        "requestBody": {
          "description": "# commerce.account_status_changed\n\nThe **Account status changed** event is triggered whenever an account\u2019s status is updated in Zoom Commerce (for example, when an account is activated, suspended, or canceled).\n\n## Prerequisites\n\nTo receive this event, ensure the following configurations are in place for your [Marketplace app](https://marketplace.zoom.us/user/build).\n\n* **Event Subscriptions** are enabled.\n* A valid **Event Notification Endpoint URL** is specified.\n* The **Commerce Account status changed** event subscription is enabled under the **commerce** event category.\n\n**[Scopes](https://developers.zoom.us/docs/integrations/oauth-scopes-overview/):** `zoom_commerce:read:admin`\n\n**[Granular Scopes](https://developers.zoom.us/docs/integrations/oauth-scopes-overview/):** `zoom_commerce:read:account:admin`\n\n**Event type**: `commerce.account_status_changed`\n",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event": {
                    "type": "string",
                    "description": "The name of the event."
                  },
                  "event_ts": {
                    "type": "integer",
                    "format": "int64",
                    "description": "The timestamp at which the event occurred."
                  },
                  "event_id": {
                    "type": "string",
                    "format": "UUID",
                    "description": "A unique identifier for the event."
                  },
                  "payload": {
                    "type": "object",
                    "properties": {
                      "account_id": {
                        "type": "string",
                        "description": "The ID of the account that triggered the webhook."
                      },
                      "account": {
                        "type": "object",
                        "description": "The account details.",
                        "properties": {
                          "crm_account_number": {
                            "type": "string",
                            "description": "The unique ID for the account in the Zoom CRM system."
                          },
                          "create_reference_id": {
                            "type": "string",
                            "description": "The unique reference ID for this account if created through the Zoom Commerce API."
                          },
                          "status": {
                            "type": "string",
                            "description": "The account's latest status: success, partial success, submitted, in review, or failure.",
                            "enum": [
                              "success",
                              "partial success",
                              "failure",
                              "submitted",
                              "in review"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              },
              "examples": {
                "json-example": {
                  "summary": "JSON example",
                  "value": "{\n  \"event\": \"account_management.status_changed\",\n  \"event_ts\": 1626230691572,\n  \"payload\": {\n    \"account_id\": \"fhedy84r34rh3bs8n9\",\n    \"account\": {\n      \"crm_account_number\": \"A-3442434\",\n      \"create_reference_id\": \"ACC-23423423\",\n      \"status\": \"success\"\n    }\n  }\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "type": "string",
                      "description": "The name of the event."
                    },
                    "event_ts": {
                      "type": "integer",
                      "format": "int64",
                      "description": "The timestamp at which the event occurred."
                    },
                    "event_id": {
                      "type": "string",
                      "format": "UUID",
                      "description": "A unique identifier for the event."
                    },
                    "payload": {
                      "type": "object",
                      "properties": {
                        "account_id": {
                          "type": "string",
                          "description": "The ID of the account that triggered the webhook."
                        },
                        "account": {
                          "type": "object",
                          "description": "The account details.",
                          "properties": {
                            "crm_account_number": {
                              "type": "string",
                              "description": "The unique ID for the account in the Zoom CRM system."
                            },
                            "create_reference_id": {
                              "type": "string",
                              "description": "The unique reference ID for this account if created through the Zoom Commerce API."
                            },
                            "status": {
                              "type": "string",
                              "description": "The account's latest status: success, partial success, submitted, in review, or failure.",
                              "enum": [
                                "success",
                                "partial success",
                                "failure",
                                "submitted",
                                "in review"
                              ]
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "json-example": {
                    "summary": "JSON example",
                    "value": "{\n  \"event\": \"account_management.status_changed\",\n  \"event_ts\": 1626230691572,\n  \"payload\": {\n    \"account_id\": \"fhedy84r34rh3bs8n9\",\n    \"account\": {\n      \"crm_account_number\": \"A-3442434\",\n      \"create_reference_id\": \"ACC-23423423\",\n      \"status\": \"success\"\n    }\n  }\n}"
                  }
                }
              }
            }
          }
        }
      }
    },
    "commerce.quote_status_changed": {
      "post": {
        "tags": [
          "commerce"
        ],
        "operationId": "commerce.quote_status_changed",
        "requestBody": {
          "description": "# commerce.quote_status_changed\nThe **Quote status changed** event is triggered every time a quote's status is updated in Zoom Commerce (for example, when a quote is submitted, approved, or canceled).\n\n## Prerequisites\n\nTo receive this event, ensure the following configurations are in place for your [Marketplace app](https://marketplace.zoom.us/user/build).\n\n* **Event Subscriptions** are enabled.\n* A valid **Event Notification Endpoint URL** is specified.\n* The **Quote status changed** event subscription is enabled under the **commerce** event category.\n\n**[Scopes](https://developers.zoom.us/docs/integrations/oauth-scopes-overview/):** `zoom_commerce:read:admin`\n\n**[Granular Scopes](https://developers.zoom.us/docs/integrations/oauth-scopes-overview/):** `zoom_commerce:read:quote:admin`\n\n**Event type**: `commerce.quote_status_changed`\n",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event": {
                    "type": "string",
                    "description": "The name of the event."
                  },
                  "event_ts": {
                    "type": "integer",
                    "format": "int64",
                    "description": "The timestamp at which the event occurred."
                  },
                  "event_id": {
                    "type": "string",
                    "format": "UUID",
                    "description": "A unique identifier for the event."
                  },
                  "payload": {
                    "type": "object",
                    "properties": {
                      "account_id": {
                        "type": "string",
                        "description": "The ID of the account that triggered the webhook."
                      },
                      "quote": {
                        "type": "object",
                        "description": "The quote details.",
                        "properties": {
                          "quote_reference_id": {
                            "type": "string",
                            "description": "Reference ID for a quote.",
                            "example": "Q-3248714941"
                          },
                          "status": {
                            "type": "string",
                            "description": "The status of the quote.",
                            "example": "approved",
                            "enum": [
                              "failedToSubmit",
                              "completed",
                              "canceled",
                              "submitted",
                              "failed",
                              "approved",
                              "rejected",
                              "returned",
                              "provisioning",
                              "draft"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              },
              "examples": {
                "json-example": {
                  "summary": "JSON example",
                  "value": "{\n  \"event\": \"commerce.order_status_changed\",\n  \"event_ts\": 1626230691572,\n  \"event_id\": \"fhewu234fhuf2394e78\",\n  \"payload\": {\n    \"account_id\": \"r8489rjfhdsbj7623_er7r\",\n    \"quote\": {\n      \"quote_reference_id\": \"Q-23423423\",\n      \"status\": \"approved\"\n    }\n  }\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "type": "string",
                      "description": "The name of the event."
                    },
                    "event_ts": {
                      "type": "integer",
                      "format": "int64",
                      "description": "The timestamp at which the event occurred."
                    },
                    "event_id": {
                      "type": "string",
                      "format": "UUID",
                      "description": "A unique identifier for the event."
                    },
                    "payload": {
                      "type": "object",
                      "properties": {
                        "account_id": {
                          "type": "string",
                          "description": "The ID of the account that triggered the webhook."
                        },
                        "quote": {
                          "type": "object",
                          "description": "The quote details.",
                          "properties": {
                            "quote_reference_id": {
                              "type": "string",
                              "description": "Reference ID for a quote.",
                              "example": "Q-3248714941"
                            },
                            "status": {
                              "type": "string",
                              "description": "The status of the quote.",
                              "example": "approved",
                              "enum": [
                                "failedToSubmit",
                                "completed",
                                "canceled",
                                "submitted",
                                "failed",
                                "approved",
                                "rejected",
                                "returned",
                                "provisioning",
                                "draft"
                              ]
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "json-example": {
                    "summary": "JSON example",
                    "value": "{\n  \"event\": \"commerce.order_status_changed\",\n  \"event_ts\": 1626230691572,\n  \"event_id\": \"fhewu234fhuf2394e78\",\n  \"payload\": {\n    \"account_id\": \"r8489rjfhdsbj7623_er7r\",\n    \"quote\": {\n      \"quote_reference_id\": \"Q-23423423\",\n      \"status\": \"approved\"\n    }\n  }\n}"
                  }
                }
              }
            }
          }
        }
      }
