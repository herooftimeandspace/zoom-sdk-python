    "commerce.deal_registration_status_changed": {
      "post": {
        "tags": [
          "commerce"
        ],
        "operationId": "commerce.deal_registration_status_changed",
        "requestBody": {
          "description": "# commerce.deal_registration_status_changed\nThe **Deal Registration status changed** event is triggered whenever a deal registration\u2019s status is updated in Zoom Commerce (for example, when a deal registration is submitted, approved, or rejected).\n\n## Prerequisites\n\nTo receive this event, ensure the following configurations are in place for your [Marketplace app](https://marketplace.zoom.us/user/build).\n\n* **Event Subscriptions** are enabled.\n* A valid **Event Notification Endpoint URL** is specified.\n* The **Deal Registration status changed** event subscription is enabled under the **commerce** event category.\n\n**[Scopes](https://developers.zoom.us/docs/integrations/oauth-scopes-overview/):** `zoom_commerce:read:admin`\n\n**[Granular Scopes](https://developers.zoom.us/docs/integrations/oauth-scopes-overview/):** `zoom_commerce:read:deal_registration:admin`\n\n**Event type**: `commerce.deal_registration_status_changed`\n",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event": {
                    "type": "string",
                    "description": "The name of the event."
                  },
                  "event_ts": {
                    "type": "integer",
                    "format": "int64",
                    "description": "The timestamp at which the event occurred."
                  },
                  "event_id": {
                    "type": "string",
                    "format": "UUID",
                    "description": "A unique identifier for the event."
                  },
                  "payload": {
                    "type": "object",
                    "properties": {
                      "account_id": {
                        "type": "string",
                        "description": "The ID of the account that triggered the webhook."
                      },
                      "deal_registration": {
                        "type": "object",
                        "description": "The deal registration details.",
                        "properties": {
                          "deal_reg_number": {
                            "maxLength": 15,
                            "type": "string",
                            "description": "The deal registration number.",
                            "example": "DR-135621"
                          },
                          "create_reference_id": {
                            "type": "string",
                            "description": "The unique reference ID for this deal registration if created using the Deal Registration API.",
                            "example": "DRR-4834729"
                          },
                          "status": {
                            "type": "string",
                            "description": "The deal registration's status.",
                            "example": "approved",
                            "enum": [
                              "pending review",
                              "denied",
                              "returned",
                              "approved",
                              "expired",
                              "revoked",
                              "closed-lost",
                              "closed-won",
                              "failure",
                              "pending sales review",
                              "draft",
                              "submitted",
                              "submit failed"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              },
              "examples": {
                "json-example": {
                  "summary": "JSON example",
                  "value": "{\n  \"event\": \"commerce.deal_registration_status_changed\",\n  \"event_ts\": 1626230691572,\n  \"event_id\": \"fhewu234fhuf2394e78\",\n  \"payload\": {\n    \"account_id\": \"r8489rjfhdsbj7623_er7r\",\n    \"deal_registration\": {\n      \"deal_reg_number\": \"DR-135621\",\n      \"create_reference_id\": \"DRR-23423423\",\n      \"status\": \"approved\"\n    }\n  }\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "type": "string",
                      "description": "The name of the event."
                    },
                    "event_ts": {
                      "type": "integer",
                      "format": "int64",
                      "description": "The timestamp at which the event occurred."
                    },
